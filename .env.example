# main_db PostgreSQL URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ezyreview:ezyreview@db:5432/main_db

# 테넌트 DB 생성용 maintenance URL (asyncpg 직접 연결, postgres DB 경유)
POSTGRES_MAINTENANCE_URL=postgresql://ezyreview:ezyreview@db:5432/postgres

# Redis (Celery 브로커 + API 키 캐시)
REDIS_URL=redis://redis:6379/0

# 인사이트 API JWT 인증키
JWT_SECRET=change-me-in-production

# 3주차 연동 예정
OPENAI_API_KEY=
KAKAO_API_KEY=
