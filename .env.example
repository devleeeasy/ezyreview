# -------------------------------------------------------
# 로컬 개발 (Docker Compose)
# -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ezyreview:ezyreview@db:5432/main_db
POSTGRES_MAINTENANCE_URL=postgresql://ezyreview:ezyreview@db:5432/postgres
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------
# Railway 배포 시 환경변수 설정 방법
#
# 1. Railway 대시보드 → PostgreSQL 플러그인 추가
#    DATABASE_URL      → Railway 제공 URL의 드라이버를 asyncpg로 교체
#                        postgresql://... → postgresql+asyncpg://...
#                        (미변환 시 자동 변환됨)
#    POSTGRES_MAINTENANCE_URL → 미설정 시 DATABASE_URL에서 자동 유도
#
# 2. Railway 대시보드 → Redis 플러그인 추가
#    REDIS_URL         → Railway가 제공하는 URL 그대로 사용
#
# 예시)
# DATABASE_URL=postgresql+asyncpg://postgres:pass@host.railway.internal:5432/railway
# REDIS_URL=redis://default:pass@host.railway.internal:6379
# -------------------------------------------------------

# JWT 서명 키 (프로덕션에서 반드시 변경)
JWT_SECRET=change-me-in-production

# OpenAI API 키 (AI 리뷰 분석 — 미설정 시 dev 모드 더미 반환)
OPENAI_API_KEY=

# Gmail SMTP (리뷰 요청 이메일 발송 — 미설정 시 dev 모드 로그만 출력)
# 앱 비밀번호 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=

# 카카오 알림톡 키 (실서비스 전환 시 사용, 현재 Gmail로 대체)
KAKAO_API_KEY=
